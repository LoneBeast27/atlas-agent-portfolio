# Last Resort Hub Environment Variables

# SpacetimeDB
STDB_URI=http://stdb:3000
STDB_MODULE=atlas-hub

# API Gateway
GATEWAY_PORT=3005

# n8n
N8N_URL=http://n8n:5678
N8N_API_KEY=your-n8n-api-key

# Qdrant
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=your-qdrant-api-key

# Prometheus
PROMETHEUS_URL=http://prometheus:9090

# Uptime Kuma
UPTIME_KUMA_URL=http://uptime-kuma:3001

# Frontend
VITE_GATEWAY_URL=http://localhost:3006
VITE_STDB_URI=ws://localhost:3004
