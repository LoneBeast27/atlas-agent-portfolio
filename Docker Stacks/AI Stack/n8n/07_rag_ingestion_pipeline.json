            "typeVersion": 2,
            "position": [
                0,
                0
            ],
            "id": "trigger-webhook",
            "name": "Webhook Trigger"
        },
        {
            "parameters": {
                "dataType": "string",
                "value1": "={{ $json.body.url }}",
                "rules": {
                    "rules": [
                        {
                            "value2": "regex:^https?://",
                            "operation": "regex"
                        }
                    ]
                }
            },
            "type": "n8n-nodes-base.switch",
            "typeVersion": 3,
            "position": [
                200,
                0
            ],
            "id": "switch-url-vs-file",
            "name": "URL vs Binary"
        },
        {
            "parameters": {
                "url": "={{ $json.body.url }}",
                "options": {}
            },
            "type": "n8n-nodes-base.httpRequest",
            "typeVersion": 4.2,
            "position": [
                400,
                -100
            ],
            "id": "fetch-website",
            "name": "HTTP Request"
        },
        {
            "parameters": {
                "operation": "extractHtmlContent",
                "extractionValues": {
                    "values": [
                        {
                            "key": "text",
                            "cssSelector": "body",
                            "returnValue": "text"
                        }
                    ]
