            "type": "@n8n/n8n-nodes-langchain.vectorStoreQdrant",
            "typeVersion": 1,
            "position": [
                1000,
                0
            ],
            "id": "qdrant-vector-store",
            "name": "Qdrant Vector Store",
            "credentials": {
                "qdrantApi": {
                    "id": "qdrant-local",
                    "name": "Local Qdrant"
                }
            }
        }
    ],
    "connections": {
        "Webhook Trigger": {
            "main": [
                [
                    {
