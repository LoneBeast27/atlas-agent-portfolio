                "options": {}
            },
            "type": "n8n-nodes-base.html",
            "typeVersion": 1.2,
            "position": [
                600,
                -100
            ],
            "id": "extract-html",
            "name": "HTML Extract"
        },
        {
            "parameters": {
                "options": {}
